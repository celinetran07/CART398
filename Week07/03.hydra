// 03

shape(3,0.5,0.001).repeat(19,19)
  .mult(osc(10,1,2))
  .rotate( ({time}) => time%360 )
  .scrollX(1,-0.25)
  .mult(shape(15,0.3,0.01)
  .rotate( ({time}) => time%360 )
  .scrollX(1,-0.55))
  .repeatY(6.0, 0.1)
  .repeatX(70.0, 0)
  .pixelate(30,30)
  .out(o0)
