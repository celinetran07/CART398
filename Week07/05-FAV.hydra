// 05

voronoi(5,1,2)
  .diff(shape(1,1.1,0.01)
        .scale(()=>Math.sin(time)*0.05 + 0.9)
        .kaleid(60)
        .color(9,2,1)
        .rotate(()=>time%360))
  .out()
