//02

osc(50,-0.03,6)
  .pixelate(50)
  .add(noise(2))
  .kaleid(()=>(Math.sin(time/8)*9+3))
  .rotate(2.5,0.5)
  .modulateRotate(shape(3).scale(()=>(Math.cos(time)*1.5)).rotate(0,-0.15))
  .diff(src(o0).brightness(0.6))
  .out()
