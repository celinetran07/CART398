//04

noise(18)
  .color(78, 3, 0.2) 
  .posterize(8)
  .kaleid(50)
  .mask(
    shape(20, 0.50).modulateScale(noise(10, 5))
  )
  .contrast( () => Math.sin(time) * 0.5 )
  .rotate(() => time * 0.2)
  .out();
