//05

osc(100)
  .color(0.3,0.5,0.9)
  .rotate(10, 0.5)
  .posterize(10)
  .modulate(osc(1).rotate(0.3).add(o0, 1))
  .add(shape(2, 0.4, 0.01).rotate(() => time * 0.2)).out(o0)

osc(50)
  .color(10,10,10)
render(o1)
